# ============================================================
# MealMind Web — Environment Variables Template
# ============================================================
# Tạo file .env.local từ file này và điền giá trị thực

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API — để trống sẽ dùng proxy rewrite
NEXT_PUBLIC_API_URL=

# Internal API URL cho Next.js rewrite
# Local: http://localhost:4000 | Docker: http://api:4000
API_INTERNAL_URL=http://localhost:4000

# Auth
NEXTAUTH_SECRET=change-me-in-production
