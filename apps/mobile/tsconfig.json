{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@mealmind/types": ["../../packages/types/src"],
      "@mealmind/utils": ["../../packages/utils/src"],
      "@mealmind/validation": ["../../packages/validation/src"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts"],
  "exclude": ["node_modules"]
}
