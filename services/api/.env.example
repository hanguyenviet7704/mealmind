# ============================================================
# MealMind API — Environment Variables
# ============================================================
# Copy thành .env.local (local) hoặc set trực tiếp trên Railway

# Server
PORT=4000
NODE_ENV=production
CORS_ORIGIN=https://your-web-app.railway.app

# Database — Railway tự inject DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# Redis — Railway tự inject REDIS_URL
# Nếu dùng host/port riêng:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_URL=redis://default:password@host:6379

# JWT
JWT_ACCESS_SECRET=change-me-strong-random-string
JWT_REFRESH_SECRET=change-me-another-strong-random-string
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# OAuth (tùy chọn)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Recommendation Service
RECOMMENDATION_SERVICE_URL=http://localhost:8000

# Meilisearch (tùy chọn)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# Weather API (tùy chọn)
WEATHER_API_KEY=
WEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather
