// MealMind Database Schema
// Source of truth cho database structure. Xem docs/architecture/database-schema.md cho ERD và giải thích.
// Xem docs/data/master-data.md cho enum values và ý nghĩa.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum SubscriptionTier {
  free
  pro
}

enum AgeRange {
  child_under_6
  child_6_12
  teen
  adult
  senior
}

enum DietType {
  normal
  lacto_ovo_vegetarian
  vegan
  keto
  low_carb
  paleo
}

enum CookTimeRange {
  under_15
  fifteen_to_30  // "15_to_30" not valid identifier
  thirty_to_60
  over_60
}

enum CuisineType {
  north
  central
  south
  international
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum DifficultyLevel {
  easy
  medium
  hard
}

enum IngredientCategory {
  protein
  vegetable
  fruit
  grain
  dairy
  seasoning
  oil
  other
}

enum IngredientGroup {
  main
  seasoning
  garnish
}

enum InteractionAction {
  view
  skip
  save
  cook
}

enum InteractionSource {
  home
  search
  combo
  surprise
  meal_plan
}

enum PlanStatus {
  draft
  active
  archived
}

enum SharePermission {
  viewer
  editor
}

enum ReligiousDiet {
  none
  buddhist_lunar
  halal
  kosher
}

enum PurineLevel {
  low
  medium
  high
}

enum NutritionPreset {
  maintain
  weight_loss
  muscle_gain
  diabetic
  custom
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id                   String           @id @default(uuid()) @db.VarChar(255)
  email                String           @unique @db.VarChar(255)
  passwordHash         String?          @map("password_hash") @db.VarChar(255) // null cho OAuth-only users
  name                 String           @db.VarChar(100)
  avatarUrl            String?          @map("avatar_url") @db.VarChar(500)
  subscriptionTier     SubscriptionTier @default(free) @map("subscription_tier")
  activeProfileId      String?          @map("active_profile_id") @db.VarChar(255) // null = family mode
  onboardingCompleted  Boolean          @default(false) @map("onboarding_completed")
  googleId             String?          @unique @map("google_id") @db.VarChar(255)
  appleId              String?          @unique @map("apple_id") @db.VarChar(255)
  deletedAt            DateTime?        @map("deleted_at") @db.DateTime(3) // soft delete
  createdAt            DateTime         @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.DateTime(3)

  // Relations
  tasteProfiles          TasteProfile[]
  dietaryRestrictions    DietaryRestriction[]
  mealLogs               MealLog[]
  userInteractions       UserInteraction[]
  mealPlans              MealPlan[]
  bookmarks              Bookmark[]
  refreshTokens          RefreshToken[]
  nutritionGoals         NutritionGoal[]
  ownedShares            MealPlanShare[]        @relation("ShareOwner")
  receivedShares         MealPlanShare[]        @relation("ShareReceiver")
  shoppingLists          ShoppingList[]
  notifications          Notification[]
  notificationSettings   NotificationSetting[]
  userPreference         UserPreference?

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.VarChar(255)
  userId     String    @map("user_id") @db.VarChar(255)
  tokenHash  String    @map("token_hash") @db.VarChar(255) // SHA-256 of raw token
  deviceInfo String?   @map("device_info") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.DateTime(3)
  createdAt  DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  revokedAt  DateTime? @map("revoked_at") @db.DateTime(3) // null = active

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================================
// TASTE PROFILES & DIETARY
// ============================================================

model TasteProfile {
  id          String        @id @default(uuid()) @db.VarChar(255)
  userId      String        @map("user_id") @db.VarChar(255)
  profileName String        @map("profile_name") @db.VarChar(50)
  isPrimary   Boolean       @default(false) @map("is_primary")
  ageRange    AgeRange?     @map("age_range")
  regions     Json @default("[]") // [north, central, south, international]
  spiceLevel  Int           @default(3) @map("spice_level") @db.SmallInt // 1-5
  sweetLevel  Int           @default(3) @map("sweet_level") @db.SmallInt
  saltLevel   Int           @default(3) @map("salt_level") @db.SmallInt
  dietType    DietType      @default(normal) @map("diet_type")
  maxCookTime CookTimeRange @default(thirty_to_60) @map("max_cook_time")
  familySize  Int           @default(2) @map("family_size") @db.SmallInt // 1-20
  createdAt   DateTime      @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.DateTime(3)

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  dietaryRestrictions DietaryRestriction[]
  nutritionGoals      NutritionGoal[]

  @@index([userId])
  @@map("taste_profiles")
}

model DietaryRestriction {
  id                    String        @id @default(uuid()) @db.VarChar(255)
  userId                String        @map("user_id") @db.VarChar(255)
  profileId             String        @map("profile_id") @db.VarChar(255)
  allergens             Json @default("[]") // [shellfish, peanuts, gluten, dairy, eggs, soy, tree_nuts]
  medicalConditions     Json @default("[]") @map("medical_conditions") // [diabetes, hypertension, gout, kidney]
  religiousDiet         ReligiousDiet @default(none) @map("religious_diet")
  blacklistedIngredients Json     @default("[]") @map("blacklisted_ingredients") // ingredient IDs
  customBlacklist       Json @default("[]") @map("custom_blacklist") // free text
  createdAt             DateTime      @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.DateTime(3)

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile TasteProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([profileId])
  @@map("dietary_restrictions")
}

// ============================================================
// RECIPES & INGREDIENTS
// ============================================================

model Recipe {
  id              String          @id @default(uuid()) @db.VarChar(255)
  name            String          @db.VarChar(200)
  nameAscii       String          @map("name_ascii") @db.VarChar(200) // không dấu, cho search
  slug            String          @unique @db.VarChar(250)
  description     String          @db.Text
  cuisine         CuisineType
  mealTypes       Json            @map("meal_types")
  difficulty      DifficultyLevel
  cookTime        Int             @map("cook_time") @db.SmallInt // phút
  prepTime        Int             @map("prep_time") @db.SmallInt
  servings        Int             @default(2) @db.SmallInt
  imageUrl        String?         @map("image_url") @db.VarChar(500)
  videoUrl        String?         @map("video_url") @db.VarChar(500)
  tags            Json            @default("[]")
  isPublished     Boolean         @default(false) @map("is_published")
  popularityScore Float           @default(0) @map("popularity_score")
  createdAt       DateTime        @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.DateTime(3)

  // Relations
  ingredients   RecipeIngredient[]
  steps         RecipeStep[]
  nutritionInfo NutritionInfo?
  mealLogs      MealLog[]
  interactions  UserInteraction[]
  planItems     MealPlanItem[]
  bookmarks     Bookmark[]

  @@index([cuisine])
  @@index([difficulty])
  @@index([cookTime])
  @@index([isPublished])
  @@index([popularityScore(sort: Desc)])
  @@map("recipes")
}

model Ingredient {
  id            String             @id @default(uuid()) @db.VarChar(255)
  name          String             @unique @db.VarChar(100)
  nameAscii     String             @map("name_ascii") @db.VarChar(100)
  category      IngredientCategory
  season        Json               @default("[]") // [spring, summer, autumn, winter] — empty = quanh năm
  avgPricePerKg Decimal?           @map("avg_price_per_kg") @db.Decimal(10, 0) // VND
  allergenTags  Json               @default("[]") @map("allergen_tags") // [shellfish, peanuts, ...]
  isCommon      Boolean            @default(true) @map("is_common")
  createdAt     DateTime           @default(now()) @map("created_at") @db.DateTime(3)

  // Relations
  recipeIngredients RecipeIngredient[]
  nutrients         IngredientNutrient?

  @@index([category])
  @@map("ingredients")
}

model IngredientNutrient {
  ingredientId    String      @id @map("ingredient_id") @db.VarChar(255)
  caloriesPer100g Decimal?    @map("calories_per_100g") @db.Decimal(8, 2) // kcal
  proteinPer100g  Decimal?    @map("protein_per_100g") @db.Decimal(8, 2)
  carbsPer100g    Decimal?    @map("carbs_per_100g") @db.Decimal(8, 2)
  fatPer100g      Decimal?    @map("fat_per_100g") @db.Decimal(8, 2)
  fiberPer100g    Decimal?    @map("fiber_per_100g") @db.Decimal(8, 2)
  sodiumPer100g   Decimal?    @map("sodium_per_100g") @db.Decimal(8, 2) // mg
  sugarPer100g    Decimal?    @map("sugar_per_100g") @db.Decimal(8, 2)
  glycemicIndex   Int?        @map("glycemic_index") @db.SmallInt // 0-100
  purineLevel     PurineLevel? @map("purine_level")
  source          String?     @db.VarChar(50) // USDA, VNIN

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@map("ingredient_nutrients")
}

model RecipeIngredient {
  id           String          @id @default(uuid()) @db.VarChar(255)
  recipeId     String          @map("recipe_id") @db.VarChar(255)
  ingredientId String          @map("ingredient_id") @db.VarChar(255)
  quantity     Decimal         @db.Decimal(10, 2)
  unit         String          @db.VarChar(30) // gram, ml, tbsp, tsp, quả, lát...
  groupType    IngredientGroup @default(main) @map("group_type")
  isOptional   Boolean         @default(false) @map("is_optional")
  sortOrder    Int             @default(0) @map("sort_order") @db.SmallInt

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
  @@index([recipeId])
  @@index([ingredientId])
  @@map("recipe_ingredients")
}

model RecipeStep {
  id              String  @id @default(uuid()) @db.VarChar(255)
  recipeId        String  @map("recipe_id") @db.VarChar(255)
  stepNumber      Int     @map("step_number") @db.SmallInt // 1-based
  description     String  @db.Text
  imageUrl        String? @map("image_url") @db.VarChar(500)
  durationMinutes Int?    @map("duration_minutes") @db.SmallInt // có → hiển thị timer

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, stepNumber])
  @@index([recipeId])
  @@map("recipe_steps")
}

model NutritionInfo {
  recipeId     String   @id @map("recipe_id") @db.VarChar(255)
  calories     Decimal  @db.Decimal(8, 1) // kcal per serving
  protein      Decimal  @db.Decimal(8, 1)
  carbs        Decimal  @db.Decimal(8, 1)
  fat          Decimal  @db.Decimal(8, 1)
  fiber        Decimal? @db.Decimal(8, 1)
  sodium       Decimal? @db.Decimal(8, 1) // mg
  sugar        Decimal? @db.Decimal(8, 1)
  isManual     Boolean  @default(false) @map("is_manual") // admin override vs calculated
  calculatedAt DateTime? @map("calculated_at") @db.DateTime(3)

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("nutrition_info")
}

// ============================================================
// USER ACTIVITY
// ============================================================

model MealLog {
  id        String   @id @default(uuid()) @db.VarChar(255)
  userId    String   @map("user_id") @db.VarChar(255)
  profileId String?  @map("profile_id") @db.VarChar(255)
  recipeId  String   @map("recipe_id") @db.VarChar(255)
  mealType  MealType @map("meal_type")
  date      DateTime @db.Date
  rating    Int?     @db.SmallInt // 1-5
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id])

  @@index([userId, date(sort: Desc)])
  @@index([recipeId])
  @@map("meal_logs")
}

model UserInteraction {
  id          String            @id @default(uuid()) @db.VarChar(255)
  userId      String            @map("user_id") @db.VarChar(255)
  recipeId    String            @map("recipe_id") @db.VarChar(255)
  action      InteractionAction
  source      InteractionSource?
  context     Json? // { mealType, weather, dayOfWeek }
  dwellTimeMs Int?              @map("dwell_time_ms") // thời gian xem recipe (ms)
  createdAt   DateTime          @default(now()) @map("created_at") @db.DateTime(3)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([recipeId])
  @@index([action])
  @@map("user_interactions")
}

model Bookmark {
  userId    String   @map("user_id") @db.VarChar(255)
  recipeId  String   @map("recipe_id") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([userId, recipeId])
  @@map("bookmarks")
}

// ============================================================
// MEAL PLANNING
// ============================================================

model MealPlan {
  id        String     @id @default(uuid()) @db.VarChar(255)
  userId    String     @map("user_id") @db.VarChar(255)
  weekStart DateTime   @map("week_start") @db.Date // Thứ 2 đầu tuần
  status    PlanStatus @default(draft)
  createdAt DateTime   @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.DateTime(3)

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  MealPlanItem[]
  shares MealPlanShare[]

  @@index([userId, status])
  @@index([userId, weekStart])
  @@map("meal_plans")
}

model MealPlanItem {
  id        String   @id @default(uuid()) @db.VarChar(255)
  planId    String   @map("plan_id") @db.VarChar(255)
  day       Int      @db.SmallInt // 1=Thứ 2, 7=Chủ nhật
  mealType  MealType @map("meal_type")
  recipeId  String   @map("recipe_id") @db.VarChar(255)
  isLocked  Boolean  @default(false) @map("is_locked")
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt

  plan   MealPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  recipe Recipe   @relation(fields: [recipeId], references: [id])

  @@unique([planId, day, mealType, sortOrder])
  @@index([planId])
  @@map("meal_plan_items")
}

model MealPlanShare {
  id           String          @id @default(uuid()) @db.VarChar(255)
  planId       String          @map("plan_id") @db.VarChar(255)
  ownerId      String          @map("owner_id") @db.VarChar(255)
  sharedWithId String          @map("shared_with_id") @db.VarChar(255)
  permission   SharePermission @default(viewer)
  createdAt    DateTime        @default(now()) @map("created_at") @db.DateTime(3)

  plan       MealPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  owner      User     @relation("ShareOwner", fields: [ownerId], references: [id])
  sharedWith User     @relation("ShareReceiver", fields: [sharedWithId], references: [id])

  @@unique([planId, sharedWithId])
  @@map("meal_plan_shares")
}

// ============================================================
// NUTRITION GOALS
// ============================================================

model NutritionGoal {
  id                String          @id @default(uuid()) @db.VarChar(255)
  userId            String          @map("user_id") @db.VarChar(255)
  profileId         String          @map("profile_id") @db.VarChar(255)
  preset            NutritionPreset @default(maintain)
  dailyCalories     Int             @default(2000) @map("daily_calories")
  dailyProteinGrams Decimal         @default(50) @map("daily_protein_grams") @db.Decimal(8, 1)
  dailyCarbGrams    Decimal         @default(275) @map("daily_carb_grams") @db.Decimal(8, 1)
  dailyFatGrams     Decimal         @default(65) @map("daily_fat_grams") @db.Decimal(8, 1)
  dailyFiberGrams   Decimal         @default(25) @map("daily_fiber_grams") @db.Decimal(8, 1)
  createdAt         DateTime        @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.DateTime(3)

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile TasteProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([userId])
  @@map("nutrition_goals")
}

// ============================================================
// SHOPPING LIST
// ============================================================

model ShoppingList {
  id         String             @id @default(uuid()) @db.VarChar(255)
  userId     String             @map("user_id") @db.VarChar(255)
  planId     String             @map("plan_id") @db.VarChar(255)
  weekLabel  String             @map("week_label") @db.VarChar(50) // "24/03 – 30/03"
  createdAt  DateTime           @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt  DateTime           @updatedAt @map("updated_at") @db.DateTime(3)

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ShoppingListItem[]

  @@index([userId])
  @@index([planId])
  @@map("shopping_lists")
}

model ShoppingListItem {
  id             String             @id @default(uuid()) @db.VarChar(255)
  listId         String             @map("list_id") @db.VarChar(255)
  ingredientName String             @map("ingredient_name") @db.VarChar(100)
  quantity       Decimal            @db.Decimal(10, 2)
  unit           String             @db.VarChar(30)
  category       IngredientCategory
  checked        Boolean            @default(false)
  sortOrder      Int                @default(0) @map("sort_order") @db.SmallInt

  list ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
  @@map("shopping_list_items")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

enum NotificationType {
  meal_suggestion
  plan_reminder
  timer_done
  weekly_report
  feature_update
  promo
}

model Notification {
  id        String           @id @default(uuid()) @db.VarChar(255)
  userId    String           @map("user_id") @db.VarChar(255)
  type      NotificationType
  title     String           @db.VarChar(200)
  body      String           @db.VarChar(500)
  link      String?          @db.VarChar(500) // deep link or route
  readAt    DateTime?        @map("read_at") @db.DateTime(3)
  createdAt DateTime         @default(now()) @map("created_at") @db.DateTime(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationSetting {
  id        String  @id @default(uuid()) @db.VarChar(255)
  userId    String  @map("user_id") @db.VarChar(255)
  type      String  @db.VarChar(50) // meal_breakfast, meal_lunch, meal_dinner, plan_reminder, shopping_reminder, timer, weekly_report, feature, promo
  enabled   Boolean @default(true)
  time      String? @db.VarChar(5) // HH:mm format, e.g. "07:00"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("notification_settings")
}

// ============================================================
// USER PREFERENCES
// ============================================================

model UserPreference {
  userId   String @id @map("user_id") @db.VarChar(255)
  language String @default("vi") @db.VarChar(5)
  unit     String @default("metric") @db.VarChar(10) // metric | imperial
  theme    String @default("light") @db.VarChar(10) // light | dark | system

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}
